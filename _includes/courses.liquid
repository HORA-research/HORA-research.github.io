<div class="col">
  <a href="{% if course.redirect %}{{ course.redirect }}{% else %}{{ course.url | relative_url }}{% endif %}">
    <div class="card h-100 hoverable">
      <div class="row no-gutters">
        <div class="col-md-12">
          <div class="card-body">
            <h3 class="card-title">{{ course.title }}</h3>
            <p class="card-text">{{ course.description }}</p>
          </div>
        </div>
      </div>
    </div>
  </a>
</div>

